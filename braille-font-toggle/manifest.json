{
  "manifest_version": 3,
  "name": "Blind Mode",
  "version": "1.0.0",
  "description": "Helps the visually impaired navigate the web without the use of text-to-speech.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "Toggle Blind Mode"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css", "fonts/BrailleFont.woff2"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
